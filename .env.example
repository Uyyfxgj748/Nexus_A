# ── Nexus-Bot — Variables de entorno ──
# Copia este archivo como .env y rellena los valores

# OBLIGATORIO: Tu número de WhatsApp (con código de país, sin + ni espacios)
PHONE_NUMBER=521234567890

# OBLIGATORIO: JID del super owner (mismo número en formato JID)
SUPER_OWNER_JID=521234567890@s.whatsapp.net

# Contraseña para el panel web /dashboard (opcional, déjala vacía para sin contraseña)
DASHBOARD_PASSWORD=

# API key de Kaiz para respuestas de IA con GPT-4o (opcional)
KAIZ_API_KEY=

# Pinterest OAuth (opcional, solo si usas descarga de Pinterest autenticada)
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Pixiv (opcional, solo si usas búsqueda de imágenes en Pixiv)
PIXIV_REFRESH_TOKEN=
